# Environment variables for The AI Course landing page.
#
# This template is committed so collaborators can see exactly what the project
# needs. REAL VALUES ARE NEVER COMMITTED — they live in Vercel
# (Project -> Settings -> Environment Variables), which persist across every
# deploy and are shared with everyone who has access to the Vercel project.
#
# A teammate with Vercel access pulls the real values locally with:
#   vercel link              # once, to connect this folder to the Vercel project
#   vercel env pull .env.local

# --- Circle: live "seats taken" on the page (api/seats.js) ---
CIRCLE_API_TOKEN=            # Circle Admin API v2 token (required for live seats)
CIRCLE_COURSE_TAG_ID=        # member-tag id for "The AI Course" buyers
CIRCLE_VIP_TAG_ID=           # member-tag id for "Build With Me (VIP)" buyers
SEATS_COURSE_SEED=0          # added on top of the live course count
SEATS_VIP_SEED=0             # added on top of the live vip count
SEATS_COURSE_TOTAL=60        # total course seats
SEATS_VIP_TOTAL=8            # total vip seats

# --- Cloudinary: only for scripts/upload-to-cloudinary.mjs (not used by the site) ---
CLOUDINARY_CLOUD=dufuwl2hx   # cloud name (public; also in index.html)
CLOUDINARY_API_KEY=          # API key    — Cloudinary dashboard
CLOUDINARY_API_SECRET=       # API secret — KEEP PRIVATE, never commit
